{
  "Agent": {
    "AgentId": "agent-poc-01",
    "ListenUrl": "http://0.0.0.0:18443",
    "DataDirectory": "data",
    "MockMode": true,
    "EnablePolling": true,
    "EnableSimulator": true,
    "SchedulerTickSeconds": 1,
    "MaxConcurrentDevices": 4,
    "EnableReadOnlyQueries": false,
    "ReadOnlyQueryMaxCommandLength": 128,
    "ReadOnlyQueryMaxOutputBytes": 65536,
    "ReadOnlyQueryRateLimitPerMinute": 12,
    "ReadOnlyQueryDeviceWaitSeconds": 5,
    "ReadOnlyQueryTotalTimeoutSeconds": 60,
    "Telnet": {
      "MaxSessionSeconds": 240,
      "ImmediateSessionCloseRetryCount": 1,
      "ImmediateSessionCloseRetryDelaySeconds": 2
    },
    "Retention": {
      "RawDays": 7,
      "RawMaxMegabytes": 500,
      "EventDays": 90,
      "AuditDays": 180
    },
    "Switches": [
      {
        "Id": "TEST-SW-01",
        "DisplayName": "Samsung access switch POC",
        "Model": "IES4224GP",
        "Host": "192.0.2.10",
        "Port": 23,
        "CredentialId": "test-switch-readonly",
        "UplinkPort": "24"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
