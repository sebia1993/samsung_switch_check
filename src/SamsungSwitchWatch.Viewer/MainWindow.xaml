<Window x:Class="SamsungSwitchWatch.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SamsungSwitchWatch.Viewer.Models"
        mc:Ignorable="d"
        Title="Samsung Switch Watch"
        Width="1440" Height="900" MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Closing="OnClosing" Loaded="OnLoaded" PreviewKeyDown="OnPreviewKeyDown"
        KeyboardNavigation.TabNavigation="Continue"
        AutomationProperties.Name="삼성 스위치 모니터링 운영 대시보드">
    <Window.Resources>
        <DataTemplate x:Key="HealthBadgeTemplate">
            <Border Padding="9,4" CornerRadius="12"
                    Background="{Binding Health, Converter={StaticResource HealthBrush}, ConverterParameter=Background}"
                    AutomationProperties.Name="{Binding Health, Converter={StaticResource HealthText}}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Margin="0,0,6,0"
                             Fill="{Binding Health, Converter={StaticResource HealthBrush}}" />
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding Health, Converter={StaticResource HealthBrush}}"
                               Text="{Binding Health, Converter={StaticResource HealthText}}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style x:Key="AccessibleEventItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="AutomationProperties.Name" Value="{Binding AccessibilityName}" />
            <Setter Property="AutomationProperties.HelpText" Value="{Binding AlertDetail}" />
            <Setter Property="AutomationProperties.ItemStatus" Value="{Binding AccessibilityStatus}" />
        </Style>

        <DataTemplate x:Key="DeviceEventTemplate">
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding Severity, Converter={StaticResource HealthBrush}}" CornerRadius="2" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                            <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Severity, Converter={StaticResource HealthText}}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding Severity, Converter={StaticResource HealthBrush}}" />
                            <TextBlock Grid.Column="2" Margin="8,0,0,0" Text="{Binding TimeText}" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                        <TextBlock Margin="0,4,0,0" Text="{Binding AlertDetail}" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:DeviceMetricDto}">
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="145" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" />
                    <Border Grid.Column="2" Padding="8,3" CornerRadius="12"
                            Background="{Binding Health, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                   Foreground="{Binding Health, Converter={StaticResource HealthBrush}}"
                                   Text="{Binding Health, Converter={StaticResource HealthText}}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:OperationalStatusDto}">
            <Border Margin="0,0,0,8" Padding="12" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Background="{Binding Health, Converter={StaticResource HealthBrush}, ConverterParameter=Background}"
                    AutomationProperties.Name="{Binding Title}"
                    AutomationProperties.ItemStatus="{Binding Code}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding Health, Converter={StaticResource HealthBrush}}" CornerRadius="2" />
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                            <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Code}" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                        <TextBlock Margin="0,4,0,0" Text="{Binding Detail}" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="SummaryValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>

    <Grid Background="{StaticResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="138" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Samsung Switch Watch" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Margin="10,0,0,0" Text="Viewer 주도형 장비 조회" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <Border Margin="8,0,0,0" Padding="9,4" CornerRadius="12"
                                Background="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Margin="0,0,6,0"
                                         Fill="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}}" />
                                <TextBlock Text="{Binding ConnectionText}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Margin="0,4,0,0" Text="{Binding LastSuccessfulReceiptText}"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Margin="0,0,8,0" Style="{StaticResource PrimaryButton}" Content="_장비 관리"
                            Click="OpenDeviceManagement_Click"
                            AutomationProperties.Name="장비 IP와 계정 관리"/>
                    <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButton}" Content="화면 _새로고침"
                            Command="{Binding RefreshCommand}" />
                    <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButton}" Content="_미니 창"
                            Click="ShowMiniWindow_Click" />
                    <Button Style="{StaticResource SecondaryButton}" Content="_Agent 연결"
                            Click="OpenSettings_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,16,24,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="208" /><ColumnDefinition Width="18" />
                <ColumnDefinition Width="208" /><ColumnDefinition Width="18" />
                <ColumnDefinition Width="208" /><ColumnDefinition Width="18" />
                <ColumnDefinition Width="208" /><ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16,12" BorderBrush="#BBF7D0">
                <StackPanel>
                    <TextBlock Text="정상" Foreground="#15803D" />
                    <TextBlock Text="{Binding NormalCount, StringFormat={}{0:N0}대}" Style="{StaticResource SummaryValue}" Foreground="#15803D" />
                    <TextBlock Text="현재 정상 장비" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16,12" BorderBrush="#FDE68A">
                <StackPanel>
                    <TextBlock Text="경고" Foreground="#B45309" />
                    <TextBlock Text="{Binding WarningCount, StringFormat={}{0:N0}대}" Style="{StaticResource SummaryValue}" Foreground="#B45309" />
                    <TextBlock Text="확인 필요 장비" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="16,12" BorderBrush="#FECACA">
                <StackPanel>
                    <TextBlock Text="문제" Foreground="#B91C1C" />
                    <TextBlock Text="{Binding CriticalDisplayCount, StringFormat={}{0:N0}대}" Style="{StaticResource SummaryValue}" Foreground="#B91C1C" />
                    <TextBlock FontSize="12" Foreground="{StaticResource MutedTextBrush}">
                        <Run Text="장애 " /><Run Text="{Binding CriticalCount, Mode=OneWay}" /><Run Text="대 · 접속 끊김 " />
                        <Run Text="{Binding DisconnectedCount, Mode=OneWay}" /><Run Text="대" />
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource CardStyle}" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="미확인 이벤트" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding UnacknowledgedCount, StringFormat={}{0:N0}건}" Style="{StaticResource SummaryValue}" />
                    <TextBlock Text="확인 처리 전 이벤트" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="8" Style="{StaticResource CardStyle}" Padding="18,12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="수집 상태" FontWeight="SemiBold" />
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Padding="8,3" CornerRadius="12"
                                Background="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                            <TextBlock Text="{Binding ConnectionText}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}}" />
                        </Border>
                    </Grid>
                    <StackPanel Grid.Row="1" Margin="0,7,0,0">
                        <TextBlock Text="{Binding MiniCurrentStatusText}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding LastSuccessfulReceiptText}" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="394" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
                        <Grid>
                            <TextBlock Text="장비" FontWeight="SemiBold" />
                            <TextBlock HorizontalAlignment="Right" Text="{Binding TotalCount, StringFormat={}{0}대}"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1">
                        <ListBox x:Name="DevicesList" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                 AutomationProperties.Name="관리 장비 목록">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                                    <Setter Property="AutomationProperties.HelpText" Value="{Binding Summary}" />
                                    <Setter Property="AutomationProperties.ItemStatus" Value="{Binding CollectionStatusText}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF" />
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                            <Setter Property="BorderThickness" Value="3,0,0,0" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Margin="0,3,0,0" Text="{Binding Model}" FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Margin="0,5,0,0" Text="{Binding CapabilityText}" FontSize="12"
                                                           Foreground="#B45309"
                                                           Visibility="{Binding HasCapabilityIssue, Converter={StaticResource BoolVisibility}}" />
                                                <TextBlock Margin="0,3,0,0" Text="{Binding Summary}" FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource HealthBadgeTemplate}" />
                                                <TextBlock Margin="0,8,0,0" Text="{Binding LastCheckedText}" FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="DevicesEmptyStateText" Text="등록된 장비가 없습니다. 상단의 장비 관리에서 IP와 계정을 등록해 주세요.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasItems, ElementName=DevicesList}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="82" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedDevice.Name, TargetNullValue=스위치를 선택하세요}"
                                           FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}">
                                    <Run Text="{Binding SelectedDevice.Model, Mode=OneWay}" /><Run Text=" · 가동 시간 " />
                                    <Run Text="{Binding SelectedDevice.Uptime, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <ContentControl Grid.Column="1" Content="{Binding SelectedDevice}"
                                            ContentTemplate="{StaticResource HealthBadgeTemplate}" VerticalAlignment="Top" />
                        </Grid>
                    </Border>
                    <TabControl Grid.Row="1" Margin="12,0,12,12" KeyboardNavigation.TabNavigation="Local"
                                AutomationProperties.Name="선택 장비 상세 정보">
                        <TabItem Header="_상태">
                            <Grid Margin="8,12,8,8">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Background="#F8FAFC" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding SelectedDevice.Summary, TargetNullValue=왼쪽 목록에서 장비를 선택하면 상태가 표시됩니다.}" />
                                </Border>
                                <Grid Grid.Row="1">
                                    <ListBox x:Name="SelectedDeviceMetricsList" ItemsSource="{Binding SelectedDevice.Metrics}" BorderThickness="0"
                                             Background="Transparent" AutomationProperties.Name="선택 장비 구조화 상태 지표">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="AutomationProperties.Name" Value="{Binding Label}" />
                                                <Setter Property="AutomationProperties.HelpText" Value="{Binding Value}" />
                                                <Setter Property="AutomationProperties.ItemStatus"
                                                        Value="{Binding Health, Converter={StaticResource HealthText}}" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                    <TextBlock Text="수집된 상태 정보가 없습니다." HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasItems, ElementName=SelectedDeviceMetricsList}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </TabItem>
                        <TabItem Header="새 _로그">
                            <Grid Margin="8,12,8,8">
                                <ListBox x:Name="SelectedDeviceLogsList" ItemsSource="{Binding SelectedDeviceLogs}" BorderThickness="0"
                                         Background="Transparent" AutomationProperties.Name="선택 장비 신규 로그"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource AccessibleEventItemStyle}"
                                         ItemTemplate="{StaticResource DeviceEventTemplate}" />
                                <TextBlock Text="새로 수신된 로그가 없습니다.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems, ElementName=SelectedDeviceLogsList}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </TabItem>
                        <TabItem Header="변경 _이력">
                            <Grid Margin="8,12,8,8">
                                <ListBox x:Name="SelectedDeviceChangesList" ItemsSource="{Binding SelectedDeviceChanges}" BorderThickness="0"
                                         Background="Transparent" AutomationProperties.Name="선택 장비 변경 이력"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource AccessibleEventItemStyle}"
                                         ItemTemplate="{StaticResource DeviceEventTemplate}" />
                                <TextBlock Text="상태 변경 이력이 없습니다.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems, ElementName=SelectedDeviceChangesList}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </TabItem>
                        <TabItem Header="장비 _명령"
                                 AutomationProperties.Name="장비 명령"
                                 AutomationProperties.HelpText="선택한 장비에서 Agent가 허용한 읽기 전용 show 명령 한 개를 실행합니다.">
                            <Grid Margin="8,12,8,8">
                                <Grid x:Name="ReadOnlyQueryEnabledPanel">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ReadOnlyQueriesEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                            CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Foreground="#92400E"
                                                       Text="조회 전용 show 명령만 실행됩니다." />
                                            <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#92400E"
                                                       Text="한 줄짜리 show 명령을 실행할 수 있습니다. 결과는 이 Viewer 창의 메모리에만 유지되며 저장·내보내기 하지 않습니다." />
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="2,0,2,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="선택 장비" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding SelectedDevice.Name, TargetNullValue=장비를 선택해 주세요.}"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                    </Grid>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ReadOnlyQueryTextBox" Height="38" Padding="10,6"
                                                 VerticalContentAlignment="Center" FontFamily="Roboto Mono, Consolas"
                                                 Text="{Binding ReadOnlyQueryCommand, UpdateSourceTrigger=PropertyChanged}"
                                                 MaxLength="{Binding ReadOnlyQueryMaxCommandLength}"
                                                 IsEnabled="{Binding CanEditReadOnlyQuery}"
                                                 KeyDown="ReadOnlyQueryTextBox_OnKeyDown"
                                                 AutomationProperties.Name="읽기 전용 show 명령"
                                                 AutomationProperties.HelpText="Enter 실행, 위아래 화살표 최근 명령, 실행 중 Esc 취소" />
                                        <Button Grid.Column="1" Margin="8,0,0,0" MinWidth="76"
                                                Style="{StaticResource PrimaryButton}" Content="_실행"
                                                Command="{Binding ExecuteReadOnlyQueryCommand}"
                                                AutomationProperties.Name="장비 명령 실행" />
                                        <Button Grid.Column="2" Margin="8,0,0,0" MinWidth="76"
                                                Style="{StaticResource SecondaryButton}" Content="_취소"
                                                Command="{Binding CancelReadOnlyQueryCommand}"
                                                AutomationProperties.Name="장비 명령 취소" />
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="2,10,2,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ReadOnlyQueryStatusTextBlock"
                                                   Text="{Binding ReadOnlyQueryStatusText}" FontWeight="SemiBold"
                                                   AutomationProperties.Name="장비 명령 실행 상태"
                                                   AutomationProperties.LiveSetting="Polite" />
                                        <TextBlock Grid.Column="1" Margin="10,0,8,0" Text="{Binding ReadOnlyQueryResultMeta}"
                                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        <Button Grid.Column="2" Padding="10,5" Margin="0,0,6,0"
                                                Style="{StaticResource SecondaryButton}" Content="복_사"
                                                Click="CopyReadOnlyQueryOutput_Click"
                                                IsEnabled="{Binding HasReadOnlyQueryOutput}"
                                                AutomationProperties.Name="장비 명령 결과 복사" />
                                        <Button Grid.Column="3" Padding="10,5"
                                                Style="{StaticResource SecondaryButton}" Content="_지우기"
                                                Command="{Binding ClearReadOnlyQueryOutputCommand}"
                                                AutomationProperties.Name="장비 명령 결과 지우기" />
                                    </Grid>

                                    <TextBox x:Name="ReadOnlyQueryOutputTextBox" Grid.Row="4"
                                             Text="{Binding ReadOnlyQueryOutput, Mode=OneWay}" IsReadOnly="True"
                                             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Roboto Mono, Consolas" FontSize="12" Padding="10"
                                             Background="#0F172A" Foreground="#E2E8F0" BorderThickness="0"
                                             AutomationProperties.Name="장비 명령 실행 결과"
                                             AutomationProperties.HelpText="Viewer 메모리에만 유지되는 읽기 전용 결과입니다." />
                                </Grid>

                                <Border x:Name="ReadOnlyQueryUnavailablePanel" Background="#F8FAFC"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="20">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ReadOnlyQueriesEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="장비 명령을 사용할 수 없습니다." FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Margin="0,7,0,0" MaxWidth="440" Text="{Binding ReadOnlyQueryUnavailableText}"
                                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                                   TextAlignment="Center"
                                                   AutomationProperties.Name="장비 명령 사용 불가 안내" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="수집 _진단">
                            <Grid Margin="8,12,8,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Background="#EFF6FF" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="장비·계정·감시 이력은 Viewer가 관리하고 Agent는 Telnet 접속만 중계합니다."
                                                   Foreground="#1E40AF" />
                                        <TextBlock Margin="0,5,0,0" FontSize="12" Foreground="#1E40AF">
                                            <Run Text="{Binding CollectorVersion, Mode=OneWay}" /><Run Text=" · " />
                                            <Run Text="{Binding ApiVersionText, Mode=OneWay}" /><Run Text=" · " />
                                            <Run Text="{Binding CollectorSummary, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="1" Text="장비별 명령 자동 선택" FontWeight="SemiBold" Margin="2,0,0,8"/>
                                <ListBox Grid.Row="2" ItemsSource="{Binding SelectedDevice.Capabilities}" BorderThickness="0"
                                         Background="Transparent" MaxHeight="210"
                                         AutomationProperties.Name="선택 장비 명령 지원 및 대체 상태">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}" />
                                            <Setter Property="AutomationProperties.HelpText" Value="{Binding SelectedCommandText}" />
                                            <Setter Property="AutomationProperties.ItemStatus" Value="{Binding StateText}" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,9">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding SelectedCommandText}" FontFamily="Roboto Mono, Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding FallbackText}" Margin="0,3,0,0" FontSize="12"
                                                                   Foreground="{StaticResource MutedTextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding StateText}" Margin="12,0,0,0" FontSize="12"
                                                               Foreground="{StaticResource MutedTextBrush}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ListBox Grid.Row="3" Margin="0,12,0,0" ItemsSource="{Binding OperationalStatuses}" BorderThickness="0"
                                         Background="Transparent" AutomationProperties.Name="Agent HTTP API SignalR DB 수집기 상태">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="AutomationProperties.Name" Value="{Binding Title}" />
                                            <Setter Property="AutomationProperties.HelpText" Value="{Binding Detail}" />
                                            <Setter Property="AutomationProperties.ItemStatus" Value="{Binding Code}" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="82" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="46" />
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
                        <Grid>
                            <TextBlock Text="최근 이벤트" FontWeight="SemiBold" />
                            <TextBlock HorizontalAlignment="Right" Text="{Binding EventCountText}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       AutomationProperties.LiveSetting="Polite" />
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Margin="12,7">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="36" /></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="132" /></Grid.ColumnDefinitions>
                        <Label Padding="0,0,0,4" Content="_검색" FontSize="12" Target="{Binding ElementName=EventSearchBox}" />
                        <Label Grid.Column="1" Padding="8,0,0,4" Content="_상태" FontSize="12"
                               Target="{Binding ElementName=EventFilterComboBox}" />
                        <TextBox x:Name="EventSearchBox" Grid.Row="1" Padding="10,6"
                                 Text="{Binding EventSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="이벤트 텍스트 검색"
                                 AutomationProperties.HelpText="장비 이름, 제목, 상세, 이벤트 유형에서 검색합니다." />
                        <ComboBox x:Name="EventFilterComboBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,0"
                                  ItemsSource="{Binding EventFilters}" DisplayMemberPath="Label"
                                  SelectedItem="{Binding SelectedEventFilter}"
                                  AutomationProperties.Name="이벤트 상태 필터">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="AutomationProperties.Name" Value="{Binding Label}" />
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </Grid>
                    <Grid Grid.Row="2">
                        <ListBox x:Name="RecentEventsList" ItemsSource="{Binding FilteredEvents}"
                                 SelectedItem="{Binding SelectedEvent}" BorderThickness="0" Background="Transparent"
                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 AutomationProperties.Name="필터된 최근 이벤트 목록">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="AutomationProperties.Name" Value="{Binding AccessibilityName}" />
                                    <Setter Property="AutomationProperties.HelpText" Value="{Binding AlertDetail}" />
                                    <Setter Property="AutomationProperties.ItemStatus" Value="{Binding AccessibilityStatus}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14"
                                            Opacity="{Binding Acknowledged, Converter={StaticResource BoolOpacity}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="5" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <Border Background="{Binding Severity, Converter={StaticResource HealthBrush}}" CornerRadius="2" />
                                            <StackPanel Grid.Column="2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DeviceName}" FontSize="12" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                                    <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding TimeText}" FontSize="12"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </Grid>
                                                <TextBlock Margin="0,6,0,0" Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Margin="0,3,0,0" Text="{Binding AlertDetail}" FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                                    <Border Padding="7,3" CornerRadius="12"
                                                            Background="{Binding Severity, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                                                        <TextBlock Text="{Binding Severity, Converter={StaticResource HealthText}}" FontSize="12"
                                                                   Foreground="{Binding Severity, Converter={StaticResource HealthBrush}}" />
                                                    </Border>
                                                    <Border Margin="6,0,0,0" Padding="7,3" CornerRadius="12" Background="#F1F5F9">
                                                        <TextBlock Text="{Binding StatusText}" FontSize="12" />
                                                    </Border>
                                                    <Button Margin="8,0,0,0" Padding="8,3" FontSize="12" Content="_확인 처리"
                                                            Visibility="{Binding CanAcknowledge, Converter={StaticResource BoolVisibility}}"
                                                            Command="{Binding DataContext.AcknowledgeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" AutomationProperties.Name="이벤트 확인 처리" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Text="조건에 맞는 이벤트가 없습니다.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasItems, ElementName=RecentEventsList}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButton}" Padding="10,5" Content="_CSV"
                                    Click="ExportCsv_Click" AutomationProperties.Name="필터된 이벤트를 익명화 CSV로 내보내기" />
                            <Button Margin="6,0,0,0" Style="{StaticResource SecondaryButton}" Padding="10,5" Content="_JSON"
                                    Click="ExportJson_Click" AutomationProperties.Name="필터된 이벤트를 익명화 JSON으로 내보내기" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#F1F5F9" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="90" Height="4" Margin="0,0,12,0" IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolVisibility}}" />
                    <TextBlock Text="{Binding OperationMessage}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                               AutomationProperties.LiveSetting="Polite" />
                </StackPanel>
                <TextBlock Grid.Column="1" HorizontalAlignment="Right" FontSize="12"
                           Text="장비 계정은 Viewer 사용자 DPAPI 보호 · 수동 원문은 화면 메모리에만 유지"
                           Foreground="{StaticResource MutedTextBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
