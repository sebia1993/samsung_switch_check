<Window x:Class="SamsungSwitchWatch.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SamsungSwitchWatch.Viewer.Models"
        mc:Ignorable="d"
        Title="Samsung Switch Watch"
        Width="1440" Height="900" MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Closing="OnClosing"
        Loaded="OnLoaded"
        AutomationProperties.Name="삼성 스위치 모니터링 대시보드">
    <Window.Resources>
        <DataTemplate x:Key="HealthBadgeTemplate">
            <Border Padding="9,4" CornerRadius="12"
                    Background="{Binding Health, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Margin="0,0,6,0"
                             Fill="{Binding Health, Converter={StaticResource HealthBrush}}" />
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding Health, Converter={StaticResource HealthBrush}}"
                               Text="{Binding Health, Converter={StaticResource HealthText}}" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:DeviceMetricDto}">
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4,10">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" />
                    <Border Grid.Column="2" Padding="8,3" CornerRadius="12" Background="{Binding Health, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{Binding Health, Converter={StaticResource HealthBrush}}"
                                   Text="{Binding Health, Converter={StaticResource HealthText}}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="112" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Samsung Switch Watch" FontSize="20" FontWeight="SemiBold" />
                        <Border Margin="12,0,0,0" Padding="9,4" CornerRadius="12" Background="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Margin="0,0,6,0" Fill="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}}" />
                                <TextBlock Text="{Binding ConnectionText}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Margin="0,4,0,0" Text="{Binding LastRefreshText}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox Width="142" Margin="0,0,8,0" ItemsSource="{Binding RegisteredChecks}" SelectedItem="{Binding SelectedCheckId}"
                              AutomationProperties.Name="등록 점검 선택" />
                    <Button Margin="0,0,8,0" Style="{StaticResource PrimaryButton}" Content="지금 점검" Command="{Binding ManualCheckCommand}"
                            AutomationProperties.Name="선택한 스위치를 지금 점검" />
                    <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButton}" Content="새로 고침" Command="{Binding RefreshCommand}"
                            AutomationProperties.Name="대시보드 새로 고침" />
                    <Button Margin="0,0,8,0" Style="{StaticResource SecondaryButton}" Content="미니 창" Click="ShowMiniWindow_Click"
                            AutomationProperties.Name="항상 위 미니 창 열기" />
                    <Button Style="{StaticResource SecondaryButton}" Content="연결 설정" Click="OpenSettings_Click"
                            AutomationProperties.Name="Agent 연결 설정 열기" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16,12">
                <StackPanel><TextBlock Text="전체 장비" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Margin="0,4,0,0" Text="{Binding TotalCount}" FontSize="26" FontWeight="SemiBold"/></StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16,12" BorderBrush="#BBF7D0">
                <StackPanel><TextBlock Text="정상" Foreground="#15803D"/><TextBlock Margin="0,4,0,0" Text="{Binding NormalCount}" FontSize="26" FontWeight="SemiBold" Foreground="#16A34A"/></StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="16,12" BorderBrush="#FDE68A">
                <StackPanel><TextBlock Text="경고" Foreground="#B45309"/><TextBlock Margin="0,4,0,0" Text="{Binding WarningCount}" FontSize="26" FontWeight="SemiBold" Foreground="#D97706"/></StackPanel>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource CardStyle}" Padding="16,12" BorderBrush="#FECACA">
                <StackPanel><TextBlock Text="장애" Foreground="#B91C1C"/><TextBlock Margin="0,4,0,0" Text="{Binding CriticalCount}" FontSize="26" FontWeight="SemiBold" Foreground="#DC2626"/></StackPanel>
            </Border>
            <Border Grid.Column="8" Style="{StaticResource CardStyle}" Padding="16,12">
                <StackPanel><TextBlock Text="새 로그 · 미확인" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Margin="0,4,0,0" FontSize="26" FontWeight="SemiBold"><Run Text="{Binding NewLogCount, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding UnacknowledgedCount, Mode=OneWay}"/></TextBlock></StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="24,8,24,16">
            <Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
                        <Grid><TextBlock Text="스위치 목록" FontWeight="SemiBold"/><TextBlock HorizontalAlignment="Right" Text="{Binding TotalCount, StringFormat={}{0}대}" Foreground="{StaticResource MutedTextBrush}"/></Grid>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" AutomationProperties.Name="등록된 스위치 목록">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger></Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,13" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,3,0,0" Text="{Binding Model, Mode=OneWay}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Summary}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <ContentControl Content="{Binding}" ContentTemplate="{StaticResource HealthBadgeTemplate}"/>
                                            <TextBlock Margin="0,7,0,0" Text="{Binding LastCheckedText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="82"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedDevice.Name, TargetNullValue=스위치를 선택하세요}" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}"><Run Text="{Binding SelectedDevice.Model, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding SelectedDevice.AddressLabel, Mode=OneWay}"/><Run Text=" · 가동 시간 "/><Run Text="{Binding SelectedDevice.Uptime, Mode=OneWay}"/></TextBlock>
                            </StackPanel>
                            <ContentControl Grid.Column="1" Content="{Binding SelectedDevice}" ContentTemplate="{StaticResource HealthBadgeTemplate}" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    <TabControl Grid.Row="1" Margin="12,0,12,12">
                        <TabItem Header="상태">
                            <Grid Margin="8,12,8,8">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Background="#F8FAFC" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding SelectedDevice.Summary, TargetNullValue=왼쪽 목록에서 장비를 선택하면 상태가 표시됩니다.}"/>
                                </Border>
                                <ListBox Grid.Row="1" ItemsSource="{Binding SelectedDevice.Metrics}" BorderThickness="0" Background="Transparent" AutomationProperties.Name="선택 장비 상태 지표"/>
                            </Grid>
                        </TabItem>
                        <TabItem Header="새 로그">
                            <Grid Margin="8,12,8,8">
                                <TextBlock Text="새 로그가 없으면 이 목록은 비어 있습니다." Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Top"/>
                                <ListBox Margin="0,30,0,0" ItemsSource="{Binding SelectedDeviceLogs}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4,10"><StackPanel><TextBlock Text="{Binding Title}" FontWeight="SemiBold"/><TextBlock Margin="0,3,0,0" Text="{Binding Detail}" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Margin="0,4,0,0" Text="{Binding TimeText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="변경 이력">
                            <ListBox Margin="8,12,8,8" ItemsSource="{Binding SelectedDeviceChanges}" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4,10" Opacity="{Binding Acknowledged, Converter={StaticResource BoolOpacity}}"><StackPanel><TextBlock Text="{Binding Title}" FontWeight="SemiBold"/><TextBlock Margin="0,3,0,0" Text="{Binding Detail}" Foreground="{StaticResource MutedTextBrush}"/><TextBlock Margin="0,4,0,0" Text="{Binding TimeText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="수집기 상태">
                            <StackPanel Margin="8,12,8,8">
                                <Border Background="#EFF6FF" CornerRadius="4" Padding="12" Margin="0,0,0,12"><TextBlock Text="Viewer에는 구조화된 상태와 이벤트만 전달됩니다. Telnet 원문과 자격 증명은 Agent PC에 남습니다." Foreground="#1E40AF"/></Border>
                                <ItemsControl ItemsSource="{Binding CollectorHealth}"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
                        <Grid><TextBlock Text="최근 이벤트" FontWeight="SemiBold"/><TextBlock HorizontalAlignment="Right" Text="{Binding UnacknowledgedCount, StringFormat=미확인 {0}}" Foreground="{StaticResource MutedTextBrush}"/></Grid>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding RecentEvents}" SelectedItem="{Binding SelectedEvent}" BorderThickness="0" Background="Transparent" AutomationProperties.Name="최근 이벤트 목록">
                        <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/></Style></ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14" Opacity="{Binding Acknowledged, Converter={StaticResource BoolOpacity}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="4"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Background="{Binding Severity, Converter={StaticResource HealthBrush}}" CornerRadius="2"/>
                                        <StackPanel Grid.Column="2">
                                            <Grid><TextBlock Text="{Binding DeviceName}" FontSize="12" FontWeight="SemiBold"/><TextBlock HorizontalAlignment="Right" Text="{Binding TimeText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/></Grid>
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Title}" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,3,0,0" Text="{Binding Detail}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                                <Border Padding="7,3" CornerRadius="12" Background="{Binding Severity, Converter={StaticResource HealthBrush}, ConverterParameter=Background}"><TextBlock Text="{Binding Severity, Converter={StaticResource HealthText}}" FontSize="11" Foreground="{Binding Severity, Converter={StaticResource HealthBrush}}"/></Border>
                                                <Button Margin="8,0,0,0" Padding="8,3" FontSize="11" Content="확인" Command="{Binding DataContext.AcknowledgeCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" AutomationProperties.Name="이벤트 확인 처리"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#F1F5F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,0">
            <Grid>
                <StackPanel Orientation="Horizontal"><ProgressBar Width="90" Height="4" Margin="0,0,12,0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolVisibility}}"/><TextBlock Text="{Binding OperationMessage}" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/></StackPanel>
                <TextBlock HorizontalAlignment="Right" Text="{Binding CollectorVersion, StringFormat=Collector {0}}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
