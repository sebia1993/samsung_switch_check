<Window x:Class="SamsungSwitchWatch.Viewer.Views.DeviceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="장비 관리" Width="980" Height="690" MinWidth="880" MinHeight="620"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        AutomationProperties.Name="Viewer 장비 및 계정 관리">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="장비 관리" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Margin="0,5,0,14" Foreground="{StaticResource MutedTextBrush}"
                           Text="장비와 계정은 이 Viewer PC의 현재 Windows 사용자에게만 저장됩니다."/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="_새 장비"
                    Click="NewDevice_Click" VerticalAlignment="Top"
                    AutomationProperties.Name="새 장비 등록"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,0">
                        <Grid>
                            <TextBlock Text="등록 장비" FontWeight="SemiBold"/>
                            <TextBlock x:Name="DeviceCountText" HorizontalAlignment="Right"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Grid>
                    </Border>
                    <ListBox x:Name="DeviceList" Grid.Row="1" BorderThickness="0"
                             SelectionChanged="DeviceList_SelectionChanged"
                             AutomationProperties.Name="Viewer에 저장된 장비 목록">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,11" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,3,0,0" FontSize="12"
                                                   Foreground="{StaticResource MutedTextBrush}">
                                            <Run Text="{Binding Model}"/><Run Text=" · "/><Run Text="{Binding Host}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,0" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="접속 미확인 · 감시 꺼짐"/>
                                                    <Setter Property="Foreground" Value="#B45309"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ConnectionVerified}" Value="True">
                                                            <Setter Property="Text" Value="접속 확인됨"/>
                                                            <Setter Property="Foreground" Value="#15803D"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding ConnectionVerified}" Value="True"/>
                                                                <Condition Binding="{Binding MonitoringEnabled}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Text" Value="접속 확인됨 · 감시 켜짐"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock x:Name="FormTitleText" Text="새 장비 등록" FontSize="18" FontWeight="SemiBold"/>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="장비명" FontWeight="SemiBold"/>
                                <TextBox x:Name="DisplayNameTextBox" Margin="0,6,0,0" Height="38" Padding="10,6"
                                         MaxLength="80" AutomationProperties.Name="장비 표시 이름"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="모델" FontWeight="SemiBold"/>
                                <ComboBox x:Name="ModelComboBox" Margin="0,6,0,0"
                                          AutomationProperties.Name="삼성 스위치 모델"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="장비 IPv4" FontWeight="SemiBold"/>
                                <TextBox x:Name="HostTextBox" Margin="0,6,0,0" Height="38" Padding="10,6"
                                         AutomationProperties.Name="장비 관리 IPv4"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="계정 ID" FontWeight="SemiBold"/>
                                <TextBox x:Name="UsernameTextBox" Margin="0,6,0,0" Height="38" Padding="10,6"
                                         MaxLength="128" AutomationProperties.Name="스위치 로그인 계정 ID"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="로그인 PW" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="PasswordBox" Margin="0,6,0,0" Height="38" Padding="10,6"
                                             MaxLength="256" AutomationProperties.Name="스위치 로그인 비밀번호"/>
                                <TextBlock x:Name="PasswordHintText" Margin="0,4,0,0" FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="enable PW (선택)" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="EnablePasswordBox" Margin="0,6,0,0" Height="38" Padding="10,6"
                                             MaxLength="256" AutomationProperties.Name="스위치 enable 비밀번호"/>
                                <CheckBox x:Name="ClearEnablePasswordCheckBox" Margin="0,5,0,0"
                                          Content="저장된 enable PW 제거"
                                          AutomationProperties.Name="저장된 enable 비밀번호 제거"/>
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="MonitoringCheckBox" Margin="0,18,0,0"
                                  Content="Viewer가 실행 중일 때 주기 감시"
                                  FontWeight="SemiBold"
                                  AutomationProperties.Name="Viewer 로컬 주기 감시"/>
                        <TextBlock Margin="0,5,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                   Text="접속 시험 성공 후 사용할 수 있습니다. Viewer 종료 시 감시가 중단됩니다. · Telnet TCP/23 고정"/>

                        <Border Margin="0,18,0,0" Padding="12" Background="#EFF6FF" BorderBrush="#BFDBFE"
                                BorderThickness="1" CornerRadius="4">
                            <TextBlock x:Name="ResultText" TextWrapping="Wrap"
                                       AutomationProperties.LiveSetting="Polite"
                                       Text="접속 시험은 저장 전에도 실행할 수 있습니다. 실패해도 장비 저장은 가능합니다."/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="DeleteButton" Style="{StaticResource SecondaryButton}" Content="장비 _삭제"
                    Click="DeleteDevice_Click" HorizontalAlignment="Left"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="TestButton" MinWidth="112" Style="{StaticResource SecondaryButton}"
                        Content="접속 _시험" Click="TestConnection_Click"/>
                <Button x:Name="SaveButton" MinWidth="112" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"
                        Content="_저장" Click="SaveDevice_Click" IsDefault="True"/>
                <Button MinWidth="86" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                        Content="닫기" Click="Close_Click" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
