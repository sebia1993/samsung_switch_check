<Window x:Class="SamsungSwitchWatch.Viewer.Views.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent 연결" Width="720" Height="700" MinWidth="640" MinHeight="560"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        AutomationProperties.Name="Agent 연결 설정">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Agent 연결" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Margin="0,6,0,18"
                       Text="Agent PC에서 만든 연결 문자열 하나만 붙여 넣으면 주소, 인증서 확인, 일회용 코드 교환을 자동으로 처리합니다."
                       Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="154"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="연결 순서" FontWeight="SemiBold" Margin="0,0,0,14"/>
                            <TextBlock Text="1  문자열 만들기" FontWeight="SemiBold"/>
                            <TextBlock Text="Agent PC에서 실행" Margin="22,3,0,16" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Text="2  붙여 넣기" FontWeight="SemiBold"/>
                            <TextBlock Text="Viewer에서 한 번 입력" Margin="22,3,0,16" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Text="3  자동 확인" FontWeight="SemiBold"/>
                            <TextBlock Text="인증서와 토큰을 안전하게 저장" Margin="22,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" x:Name="LiveSettingsPanel">
                            <TextBlock Text="연결 문자열" FontWeight="SemiBold"/>
                            <TextBox x:Name="PairingStringTextBox" Margin="0,7,0,5" MinHeight="94" Padding="10,8"
                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Roboto Mono, Consolas" FontSize="12"
                                     AutomationProperties.Name="SSW1 연결 문자열"
                                     AutomationProperties.HelpText="Agent PC에서 생성한 SSW1 콜론으로 시작하는 문자열 전체를 붙여 넣습니다."/>
                            <TextBlock Text="SSW1: 로 시작하는 전체 문자열을 입력하세요. 일회용 코드는 성공 후 다시 사용할 수 없습니다."
                                       FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>

                            <Border Margin="0,14,0,0" Padding="12" Background="#EFF6FF" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="자동으로 처리되는 항목" FontWeight="SemiBold" Foreground="#1E40AF"/>
                                    <TextBlock Margin="0,5,0,0" Foreground="#1E40AF"
                                               Text="Agent HTTPS 주소 · 인증서 SHA-256 검증 · 일회용 코드 교환 · 최종 토큰 DPAPI 저장"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <CheckBox x:Name="DemoModeCheckBox" Margin="2,16,0,0"
                          Content="오프라인 데모 모드 사용"
                          FontWeight="SemiBold" Checked="DemoMode_Changed" Unchecked="DemoMode_Changed"
                          AutomationProperties.Name="오프라인 데모 모드"/>

                <Expander x:Name="AdvancedExpander" Margin="0,14,0,0" Header="고급 설정 (기존 방식)"
                          AutomationProperties.Name="고급 연결 설정">
                    <Border Margin="0,8,0,0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="일반적으로 이 항목은 입력하지 않아도 됩니다. 기존 구성 복구나 수동 진단에만 사용하세요."
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="Agent HTTPS 주소" FontWeight="SemiBold"/>
                            <TextBox x:Name="AgentUriTextBox" Margin="0,6,0,12" Height="36" Padding="10,6"
                                     AutomationProperties.Name="Agent HTTPS 주소"/>
                            <TextBlock Text="인증서 SHA-256 지문 (최대 2개)" FontWeight="SemiBold"/>
                            <TextBox x:Name="FingerprintTextBox" Margin="0,6,0,12" Height="62" Padding="10,6"
                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Roboto Mono, Consolas" FontSize="12"
                                     AutomationProperties.Name="서버 인증서 SHA-256 지문"/>
                            <TextBlock Text="최종 Bearer 토큰" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="TokenPasswordBox" Margin="0,6,0,4" Height="36" Padding="10,6"
                                         AutomationProperties.Name="최종 Bearer 토큰"/>
                            <TextBlock Text="비워 두면 현재 저장된 토큰을 유지합니다. 토큰은 연결 문자열의 일회용 코드와 다른 값입니다."
                                       FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <CheckBox x:Name="StartMinimizedCheckBox" Margin="2,16,0,12"
                          Content="Windows 시작 시 트레이에 최소화"
                          AutomationProperties.Name="시작 시 트레이에 최소화"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ValidationText" Margin="0,0,16,0" Foreground="#DC2626"
                       VerticalAlignment="Center" AutomationProperties.LiveSetting="Assertive"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="CancelButton" Width="86" Style="{StaticResource SecondaryButton}"
                        Content="취소" IsCancel="True"/>
                <Button x:Name="SaveButton" MinWidth="122" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"
                        Content="연결 및 저장" Click="Save_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
