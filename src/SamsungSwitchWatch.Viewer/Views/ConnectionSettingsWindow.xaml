<Window x:Class="SamsungSwitchWatch.Viewer.Views.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent 연결" Width="620" Height="500" MinWidth="560" MinHeight="470"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        AutomationProperties.Name="Agent 연결 설정">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Agent 연결" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Margin="0,6,0,18"
                       Text="스위치에 접근할 수 있는 원격 PC의 Agent 주소를 입력하세요."
                       Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel x:Name="LiveSettingsPanel">
                        <TextBlock Text="원격 Agent" FontSize="16" FontWeight="SemiBold"/>

                        <Grid Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Agent 주소" FontWeight="SemiBold"/>
                                <TextBox x:Name="AgentAddressTextBox" Margin="0,7,0,0" Height="38" Padding="10,7"
                                         AutomationProperties.Name="Agent IPv4 또는 DNS 주소"
                                         AutomationProperties.HelpText="예: 10.10.10.20 또는 monitor-pc.corp.local"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                   Text="HTTPS 포트 18443을 자동 사용합니다. 주소에 https://나 포트를 붙이지 마세요."/>

                        <Border Margin="0,18,0,0" Padding="13" Background="#F0FDF4" BorderBrush="#86EFAC"
                                BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <TextBlock x:Name="TransportWarningText" Text="Agent 주소만 입력하세요"
                                           FontWeight="SemiBold" Foreground="#166534"/>
                                <TextBlock Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#166534"
                                           Text="HTTPS 보호는 자동 적용됩니다. 관리망 방화벽으로 Agent 접근을 제한하세요."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <CheckBox x:Name="DemoModeCheckBox" Margin="2,16,0,0"
                          Content="오프라인 데모 모드 사용"
                          FontWeight="SemiBold" Checked="DemoMode_Changed" Unchecked="DemoMode_Changed"
                          AutomationProperties.Name="오프라인 데모 모드"/>

                <CheckBox x:Name="StartMinimizedCheckBox" Margin="2,16,0,12"
                          Content="Windows 시작 시 트레이에 최소화"
                          AutomationProperties.Name="시작 시 트레이에 최소화"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ValidationText" Margin="0,0,16,0" Foreground="#DC2626"
                       TextWrapping="Wrap" VerticalAlignment="Center"
                       AutomationProperties.LiveSetting="Assertive"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="RetrustButton" MinWidth="132" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}" Content="이 Agent로 다시 연결"
                        Visibility="Collapsed" Click="Retrust_Click"/>
                <Button x:Name="CancelButton" Width="86" Style="{StaticResource SecondaryButton}"
                        Content="취소" IsCancel="True"/>
                <Button x:Name="SaveButton" MinWidth="138" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"
                        Content="연결 확인 및 저장" Click="Save_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
