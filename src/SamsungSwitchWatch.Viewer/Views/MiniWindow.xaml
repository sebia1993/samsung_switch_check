<Window x:Class="SamsungSwitchWatch.Viewer.Views.MiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Switch Watch 미니"
        Width="360" Height="220" MinWidth="330" MinHeight="190"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" ShowInTaskbar="False"
        Topmost="True" Background="Transparent" AllowsTransparency="True"
        Deactivated="OnDeactivated" Closing="OnClosing"
        AutomationProperties.Name="스위치 상태 미니 창">
    <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8">
        <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.18"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="44"/><RowDefinition Height="58"/><RowDefinition Height="*"/><RowDefinition Height="30"/></Grid.RowDefinitions>
            <Border Background="#0F172A" CornerRadius="8,8,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="14,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}}"/>
                        <TextBlock Margin="8,0,0,0" Text="Switch Watch" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Margin="8,0,0,0" Text="{Binding ConnectionText}" Foreground="#CBD5E1" FontSize="11"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <ToggleButton x:Name="TopmostToggle" Width="32" Height="28" IsChecked="True" Content="📌" ToolTip="항상 위" Checked="TopmostToggle_Changed" Unchecked="TopmostToggle_Changed" AutomationProperties.Name="항상 위 고정"/>
                        <Button Width="32" Height="28" Margin="4,0,0,0" Content="—" Click="Hide_Click" ToolTip="숨기기" AutomationProperties.Name="미니 창 숨기기"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="14,10,14,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"><TextBlock Text="정상" FontSize="11" Foreground="#64748B"/><TextBlock Text="{Binding NormalCount}" FontSize="20" FontWeight="SemiBold" Foreground="#16A34A"/></StackPanel>
                <StackPanel Grid.Column="1"><TextBlock Text="경고" FontSize="11" Foreground="#64748B"/><TextBlock Text="{Binding WarningCount}" FontSize="20" FontWeight="SemiBold" Foreground="#D97706"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="장애" FontSize="11" Foreground="#64748B"/><TextBlock Text="{Binding CriticalCount}" FontSize="20" FontWeight="SemiBold" Foreground="#DC2626"/></StackPanel>
                <StackPanel Grid.Column="3"><TextBlock Text="미확인" FontSize="11" Foreground="#64748B"/><TextBlock Text="{Binding UnacknowledgedCount}" FontSize="20" FontWeight="SemiBold"/></StackPanel>
            </Grid>
            <ListBox Grid.Row="2" Margin="10,0" ItemsSource="{Binding RecentEvents}" BorderThickness="0" Background="#F8FAFC" ScrollViewer.VerticalScrollBarVisibility="Hidden" AutomationProperties.Name="최근 장애 요약">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,5" Opacity="{Binding Acknowledged, Converter={StaticResource BoolOpacity}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="4"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Border Background="{Binding Severity, Converter={StaticResource HealthBrush}}" CornerRadius="2"/>
                            <StackPanel Grid.Column="2"><TextBlock Text="{Binding DeviceName}" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="{Binding Title}" FontSize="11" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/></StackPanel>
                            <TextBlock Grid.Column="3" Text="{Binding OccurredAt, StringFormat={}{0:HH:mm}}" FontSize="10" Foreground="#64748B"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Row="3" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="12,0">
                <Grid><TextBlock Text="{Binding LastRefreshText}" FontSize="10" Foreground="#64748B"/><Button HorizontalAlignment="Right" Padding="8,2" Content="전체 보기" Click="Dashboard_Click" FontSize="10" AutomationProperties.Name="전체 대시보드 열기"/></Grid>
            </Border>
        </Grid>
    </Border>
</Window>
