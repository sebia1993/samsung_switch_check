<Window x:Class="SamsungSwitchWatch.Viewer.Views.MiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Switch Watch 미니" Width="360" Height="220" MinWidth="340" MinHeight="210"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" ShowInTaskbar="False"
        Topmost="True" Background="Transparent" AllowsTransparency="True"
        Deactivated="OnDeactivated" Closing="OnClosing"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="스위치 상태 항상 위 미니 창">
    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10">
        <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.18" /></Border.Effect>
        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="48" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{Binding ConnectionHealth, Converter={StaticResource HealthBrush}}" />
                    <TextBlock Margin="8,0,0,0" Text="Switch Watch" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ToggleButton x:Name="TopmostToggle" MinWidth="64" Height="26" IsChecked="True"
                                  Content="항상 위" ToolTip="창을 다른 창보다 위에 유지"
                                  Checked="TopmostToggle_Changed" Unchecked="TopmostToggle_Changed"
                                  AutomationProperties.Name="항상 위 고정" />
                    <Button Width="28" Height="26" Margin="5,0,0,0" Content="×" Click="Hide_Click"
                            ToolTip="숨기기" AutomationProperties.Name="미니 창 숨기기" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="14" FontWeight="SemiBold">
                        <Run Text="정상 " /><Run Text="{Binding NormalCount, Mode=OneWay}" /><Run Text="대 · 경고 " />
                        <Run Text="{Binding WarningCount, Mode=OneWay}" /><Run Text="대 · 문제 " />
                        <Run Text="{Binding CriticalDisplayCount, Mode=OneWay}" /><Run Text="대" />
                    </TextBlock>
                    <TextBlock Margin="0,5,0,0" FontSize="12" Foreground="{StaticResource MutedTextBrush}">
                        <Run Text="장애 " /><Run Text="{Binding CriticalCount, Mode=OneWay}" /><Run Text="대 · 접속 끊김 " />
                        <Run Text="{Binding DisconnectedCount, Mode=OneWay}" /><Run Text="대 · " />
                        <Run Text="{Binding MiniCurrentStatusText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="1" Padding="9,4" CornerRadius="12"
                        Background="{Binding MiniIssueHealth, Converter={StaticResource HealthBrush}, ConverterParameter=Background}">
                    <TextBlock Text="{Binding UnacknowledgedDisplayText}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding MiniIssueHealth, Converter={StaticResource HealthBrush}}" />
                </Border>
            </Grid>

            <Border Grid.Row="2" Margin="0,6,0,0" Padding="12" CornerRadius="6"
                    Background="{Binding MiniIssueHealth, Converter={StaticResource HealthBrush}, ConverterParameter=Background}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    AutomationProperties.LiveSetting="Polite">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="5" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Background="{Binding MiniIssueHealth, Converter={StaticResource HealthBrush}}" CornerRadius="2" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding MiniIssueTitle}" FontWeight="SemiBold" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding MiniIssueDetail}" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <TextBlock Text="{Binding LastSuccessfulReceiptText}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                <Button HorizontalAlignment="Right" Padding="9,3" Content="_상세 보기" Click="Dashboard_Click" FontSize="12"
                        AutomationProperties.Name="전체 대시보드 열기" />
            </Grid>
        </Grid>
    </Border>
</Window>
